#!/usr/bin/env bash

# Generate AI-powered commit messages based on staged changes

staged_files=$(git diff --cached --name-status)

if [ -z "$staged_files" ]; then
    echo "No staged files found. Please stage your changes first." >&2
    exit 1
fi

echo "⏳ Generating commit messages..." >&2

# Recent commits for style/scope context
recent_commits=$(git log -n 10 --pretty=format:'%h %s')

claude --model "claude-haiku-4-5-20251001" --allowedTools "Bash(git diff --cached)" -p "You are an expert developer writing git commit messages.

Run \`git diff --cached\` to inspect the staged changes, then generate exactly 5 commit message options following conventional commits format.

**Recent Commits (for scope/style reference):**

\`\`\`
$recent_commits
\`\`\`

**Rules:**
- Format: \`type(scope): short description\` (subject max 72 chars)
- Types: feat, fix, refactor, style, docs, test, chore, perf
- Scope: short module/component name (e.g. hypr, waybar, scripts, lazygit)
- Be specific about WHAT changed and WHY — not just \"update files\"
- No period at end of subject line
- Each option should offer a different angle or abstraction level
- Capture ALL changes holistically, not per-file

**Output format (EXACT — no deviations):**

1. type(scope): description
2. type(scope): description
3. type(scope): description
4. type(scope): description
5. type(scope): description

- Output EXACTLY 5 lines
- Each line starts with \"N. \" (number, period, space)
- No blank lines, no explanations, no markdown, no code fences

Here are your 5 commit messages:"
